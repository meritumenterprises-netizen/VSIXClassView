<UserControl x:Class="MembersToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <CollectionViewSource x:Key="GroupedMembers" Source="{Binding Members}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupHeading" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBox x:Name="MembersFilterTextBox"
                 Width="Auto"
                 Margin="4"
                 TextChanged="MembersFilterTextBox_TextChanged" />

        <ListBox x:Name="MembersList"
                 Grid.Row="1"
                 ItemsSource="{Binding Source={StaticResource GroupedMembers}}"
                 DisplayMemberPath="Name"
                 MouseDoubleClick="MembersList_MouseDoubleClick">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Margin="4,8,4,2" />
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListBox.GroupStyle>
        </ListBox>
    </Grid>
</UserControl>
