<UserControl x:Class="MembersToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:platformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:shell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging">
    <UserControl.Resources>
        <CollectionViewSource x:Key="GroupedMembers" Source="{Binding Members}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupHeading" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40.154" />
                <ColumnDefinition Width="7.846"/>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Class: "
                       VerticalAlignment="Center" Grid.ColumnSpan="2" />
            <TextBlock Grid.Column="2"
                       Text="{Binding SelectedClassName}"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
        </Grid>

        <TextBox x:Name="MembersFilterTextBox"
                 Grid.Row="1"
                 Width="Auto"
                 Margin="4"
                 TextChanged="MembersFilterTextBox_TextChanged" />

        <ListBox x:Name="MembersList"
                 Grid.Row="2"
                 ItemsSource="{Binding Source={StaticResource GroupedMembers}}"
                 IsSynchronizedWithCurrentItem="False"
                 Background="{DynamicResource {x:Static platformUI:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                 Foreground="{DynamicResource {x:Static platformUI:EnvironmentColors.ToolWindowTextBrushKey}}"
                 MouseDoubleClick="MembersList_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="{x:Type ListBoxItem}">
                    <Setter Property="Background" Value="{DynamicResource {x:Static platformUI:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static platformUI:EnvironmentColors.ToolWindowTextBrushKey}}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="ToolTip" Value="{Binding TooltipText}" />
                    <Setter Property="ToolTipService.InitialShowDelay" Value="0" />
                    <EventSetter Event="ToolTipOpening" Handler="MemberItem_ToolTipOpening" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                <Border x:Name="ItemBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderThickness="0">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder"
                                                Property="Background"
                                                Value="#FFD0D0D0" />
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource ListItemTextSelectedBrushKey}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <imaging:CrispImage Moniker="{Binding IconMoniker}"
                                            Width="16"
                                            Height="16"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center" />
                        <TextBlock Loaded="MemberTextBlock_Loaded"
                                   FontSize="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="{x:Type GroupItem}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                        <Expander Background="#FFF5F5F5"
                                                  Loaded="GroupExpander_Loaded"
                                                  Expanded="GroupExpander_Expanded"
                                                  Collapsed="GroupExpander_Collapsed">
                                            <Expander.Header>
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Margin="2,8,4,2" />
                                            </Expander.Header>
                                            <ItemsPresenter />
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </ListBox.GroupStyle>
        </ListBox>

        <Grid x:Name="TypeResolutionOverlay"
              Grid.RowSpan="3"
              Panel.ZIndex="10"
              Visibility="Collapsed"
              Background="#40FFFFFF">
            <Border Width="150"
                    Height="76"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource {x:Static platformUI:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static platformUI:EnvironmentColors.ToolWindowBorderBrushKey}}"
                    BorderThickness="1"
                    Padding="12">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Grid Width="24"
                          Height="24"
                          HorizontalAlignment="Center"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform />
                        </Grid.RenderTransform>
                        <Grid.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle"
                                                         From="0"
                                                         To="360"
                                                         Duration="0:0:0.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Grid.Triggers>
                        <Ellipse Stroke="{DynamicResource {x:Static platformUI:EnvironmentColors.ToolWindowTextBrushKey}}"
                                 StrokeThickness="3"
                                 Opacity="0.25" />
                        <Path Stroke="{DynamicResource {x:Static platformUI:EnvironmentColors.ToolWindowTextBrushKey}}"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 12,2 A 10,10 0 0 1 22,12" />
                    </Grid>
                    <TextBlock Text="Loading type..."
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource {x:Static platformUI:EnvironmentColors.ToolWindowTextBrushKey}}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
