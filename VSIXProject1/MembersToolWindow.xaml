<UserControl x:Class="MembersToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBox x:Name="MembersFilterTextBox"
                 Width="Auto"
                 Margin="4"
                 TextChanged="MembersFilterTextBox_TextChanged" />

        <ListBox x:Name="MembersList"
                 Grid.Row="1"
                 DisplayMemberPath="DisplayText"
                 MouseDoubleClick="MembersList_MouseDoubleClick" />
    </Grid>
</UserControl>
